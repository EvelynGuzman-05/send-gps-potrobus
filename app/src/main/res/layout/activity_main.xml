<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#FFFFFF">

    <!-- Info del chofer -->
    <TextView
        android:id="@+id/tv_bienvenida"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bienvenido"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_unidad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Unidad asignada: —"
        android:textSize="15sp"
        android:textColor="#888888"
        android:layout_marginBottom="48dp"/>

    <!-- Botón iniciar -->
    <Button
        android:id="@+id/btn_start_tracking"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Iniciar tracking"
        android:backgroundTint="#27AE60"
        android:textColor="#FFFFFF"
        android:padding="14dp"
        android:layout_marginBottom="12dp"/>

    <!-- Botón detener -->
    <Button
        android:id="@+id/btn_stop_tracking"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Detener tracking"
        android:backgroundTint="#E74C3C"
        android:textColor="#FFFFFF"
        android:padding="14dp"
        android:enabled="false"
        android:layout_marginBottom="32dp"/>

    <!-- Cerrar sesión -->
    <Button
        android:id="@+id/btn_logout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cerrar sesión"
        android:backgroundTint="#CCCCCC"
        android:textColor="#333333"
        android:padding="10dp"/>

</LinearLayout>